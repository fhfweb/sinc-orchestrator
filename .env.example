# ============================================================
# AI Project Orchestrator OS — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The orchestrator reads these via $env: in PowerShell or os.getenv() in Python.
#
# Quick start (local-first hybrid):
#   1. Copy: cp .env.example .env
#   2. Set ORCHESTRATOR_LLM_ENABLED=1
#   3. Set ORCHESTRATOR_LLM_MODEL=ollama/qwen2.5-coder:14b
#   4. Run: ollama pull qwen2.5-coder:14b
#   5. Run: pip install -r scripts/requirements.txt
#   6. Run loop: .\orchestrator.ps1 -Action v2-loop -ProjectPath <projeto> -AgentRuntimeEngine hybrid
# ============================================================


# ── COGNITIVE ENGINE (Python LLM Runtime) ───────────────────────────────────
# Enable/disable the Python LLM runtime (Run-AgentLoop.py)
# When disabled, loop uses PowerShell-only mode (external agents: Claude/Codex/Antigravity)
ORCHESTRATOR_LLM_ENABLED=0

# LLM model via LiteLLM syntax.
# Local (Ollama):   ollama/qwen2.5-coder:14b   ollama/llama3.1:8b   ollama/deepseek-coder-v2
# Cloud (Claude):   claude-sonnet-4-6           claude-haiku-4-5-20251001
# Cloud (OpenAI):   openai/gpt-4o               openai/gpt-4o-mini
# Cloud (OpenRouter): openrouter/anthropic/claude-3-5-sonnet
ORCHESTRATOR_LLM_MODEL=ollama/qwen2.5-coder:14b

# Model parameters
ORCHESTRATOR_LLM_TEMPERATURE=0.1
ORCHESTRATOR_LLM_MAX_TOKENS=1200

# Max reasoning turns per task (lower = faster + cheaper; raise for complex tasks)
ORCHESTRATOR_LLM_MAX_TURNS=8

# Top-k for RAG memory retrieval (3=fast, 5=balanced, 10=thorough)
ORCHESTRATOR_LLM_RAG_TOP_K=3


# ── CLOUD API KEYS (only needed if using cloud models above) ─────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=


# ── MEMORY BACKENDS ──────────────────────────────────────────────────────────
# Qdrant — vector semantic search (optional, graceful degradation to keyword)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Neo4j — graph memory (optional)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=


# ── OLLAMA EMBEDDINGS (used by memory_sync.py) ───────────────────────────────
# Set to empty string to disable Ollama embeddings and use keyword-only memory
OLLAMA_EMBED_URL=http://localhost:11434/api/embeddings
OLLAMA_EMBED_MODEL=nomic-embed-text


# ── STREAMING + DASHBOARD ────────────────────────────────────────────────────
# Port for the SSE streaming server (Start-StreamingServer.py)
ORCHESTRATOR_STREAM_PORT=5001

# Dashboard auto-refresh interval (seconds)
ORCHESTRATOR_DASHBOARD_INTERVAL=60


# ── FINOPS THRESHOLDS ────────────────────────────────────────────────────────
# RAM % above which non-critical Docker containers are paused
ORCHESTRATOR_RAM_CRITICAL_PCT=85
# RAM % below which paused containers are resumed
ORCHESTRATOR_RAM_RESUME_PCT=70


# ── AGENT IDENTITIES ─────────────────────────────────────────────────────────
# Default agent name when running the loop (used in task assignment + locks)
ORCHESTRATOR_DEFAULT_AGENT=Codex

# Agents available in this environment (comma-separated, for dispatcher)
# ORCHESTRATOR_AVAILABLE_AGENTS=Codex,Claude Code,Antigravity,AI Architect
