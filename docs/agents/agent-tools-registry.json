  "tools": {
    "script_validation": {
      "script": "scripts/v2/Invoke-ScriptValidationGate.ps1",
      "requires_project_path": true
    },
    "preflight_reasoner": {
      "script": "scripts/v2/Invoke-PreFlightReasoner.ps1",
      "requires_project_path": true
    },
    "powershell_command": {
      "script": "scripts/v2/Invoke-RunPowerShellCommandTool.ps1",
      "requires_project_path": true
    },
    "step_checkpoint_read": {
      "script": "scripts/v2/Invoke-StepCheckpoint.ps1",
      "fixed_mode": "read",
      "requires_project_path": true
    },
    "step_checkpoint_write": {
      "script": "scripts/v2/Invoke-StepCheckpoint.ps1",
      "fixed_mode": "write",
      "requires_project_path": true
    },
    "step_checkpoint_clear": {
      "script": "scripts/v2/Invoke-StepCheckpoint.ps1",
      "fixed_mode": "clear",
      "requires_project_path": true
    },
    "delegation_request": {
      "script": "scripts/v2/Invoke-DelegationBus.ps1",
      "fixed_mode": "request",
      "requires_project_path": true
    },
    "delegation_list": {
      "script": "scripts/v2/Invoke-DelegationBus.ps1",
      "fixed_mode": "list",
      "requires_project_path": true
    },
    "hitl_create": {
      "script": "scripts/v2/Invoke-HITLGate.ps1",
      "fixed_mode": "create",
      "requires_project_path": true
    },
    "hitl_check": {
      "script": "scripts/v2/Invoke-HITLGate.ps1",
      "fixed_mode": "check",
      "requires_project_path": true
    },
    "stream_broadcast": {
      "script": "scripts/v2/Invoke-StreamingBroadcast.ps1",
      "requires_project_path": true
    },
    "register_ephemeral_tool": {
      "handler": "python-native",
      "description": "Forge a new ephemeral tool at runtime (writes to workspace/tmp_tools/)"
    },
    "ephemeral_tool_run": {
      "script": "scripts/v2/Invoke-EphemeralToolRunner.ps1",
      "requires_project_path": true
    },
    "list_ephemeral_tools": {
      "handler": "python-native",
      "description": "List registered ephemeral tools for this project"
    },
    "graph_query": {
      "handler": "python-native",
      "description": "Run Cypher queries against Neo4j knowledge graph via graph_query.py"
    },
    "spawn_sub_agent": {
      "handler": "python-native",
      "description": "Spawn an in-memory micro-LLM sub-agent for inline review/audit tasks"
    }
  }
}
