# ─────────────────────────────────────────────────────────────────────────────
# Orchestrator Client — Environment Variables
# Copy to .env and fill in your values.
# Obtain ORCHESTRATOR_API_KEY from: POST /admin/tenants  (X-Admin-Key header)
# ─────────────────────────────────────────────────────────────────────────────

# Required: Orchestrator connection
ORCHESTRATOR_URL=http://localhost:8765
ORCHESTRATOR_API_KEY=sk-your-api-key-here

# Required: Project identity
PROJECT_ID=my-project
TENANT_ID=my-tenant

# Optional: Path to your project (defaults to current directory)
# PROJECT_PATH=.

# Optional: Agent configuration
AGENT_NAME=agent-worker
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_TOKENS=8192
AGENT_POLL_INTERVAL=15

# Optional: AI backend keys
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M

# Optional: Knowledge graph backends
NEO4J_URI=bolt://host.docker.internal:7687
NEO4J_USER=neo4j
NEO4J_PASS=changeme-neo4j-password
QDRANT_HOST=host.docker.internal
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: Loop configuration
ORCHESTRATOR_LOOP_INTERVAL_SECONDS=120
ORCHESTRATOR_LOOP_MAX_CYCLES=0
