# ─────────────────────────────────────────────────────────────────────────────
# SINC Orchestrator — Environment Variables
# Copy this file to .env and fill in the required values.
# Variables marked with (*) are REQUIRED — the compose will fail-fast if absent.
# ─────────────────────────────────────────────────────────────────────────────

# ── SECURITY (required) ───────────────────────────────────────────────────────

# (*) PostgreSQL password for the orchestrator database
ORCH_DB_PASSWORD=change-me-strong-password

# (*) Master key for /admin/* endpoints (X-Admin-Key header)
ADMIN_API_KEY=sk-admin-change-me

# (*) Neo4j auth (format: username/password)
NEO4J_AUTH=neo4j/change-me-neo4j-password

# Redis password — REQUIRED in production, leave blank for local dev.
# If APP_ENV=production and this is empty, a security warning is logged on startup.
REDIS_PASSWORD=

# Runtime environment. Enables/disables production safety checks.
# Valid values: development | production
APP_ENV=development

# ── RATE LIMITING ─────────────────────────────────────────────────────────────

# Behavior when Redis is unavailable:
#   false (default) — fail-safe: deny all requests (recommended for production)
#   true            — fail-open: allow requests via in-memory per-process fallback
# WARNING: fail-open means a Redis outage silently disables rate limiting.
RATE_LIMIT_FAIL_OPEN=false

# ── LLM PROVIDERS ────────────────────────────────────────────────────────────

# Anthropic Claude (optional — pro/enterprise plans only)
ANTHROPIC_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────

# Allowed origins for browser clients. Use * for dev, specific domains for prod.
CORS_ORIGINS=https://your-frontend.com

# ── GIT WEBHOOKS ──────────────────────────────────────────────────────────────

# HMAC secret for validating GitHub/GitLab push webhooks (optional)
GIT_WEBHOOK_SECRET=

# ── OLLAMA MODELS ─────────────────────────────────────────────────────────────

OLLAMA_MODEL_GENERAL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_MODEL_CODE=qwen2.5-coder:14b-instruct-q4_K_M
OLLAMA_MODEL_REASONING=qwen2.5:32b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── FEATURES ─────────────────────────────────────────────────────────────────

# Enable/disable self-service tenant signup via POST /signup (default: true)
SIGNUP_ENABLED=true

# Max request body size in bytes (default: 2097152 = 2 MB)
# MAX_REQUEST_BYTES=2097152

# Alert webhook URL for operational alerts (optional)
# ORCH_ALERT_WEBHOOK_URL=https://hooks.slack.com/...
